# 1. Cargamos manualmente el script de Flutter que define las funciones
flutter_install_all_ios_pods_file = File.join(File.dirname(File.realpath(__FILE__)), '.symlinks', 'plugins', 'flutter_plugin_loader', 'ios', 'podhelper.rb')
if File.exist?(flutter_install_all_ios_pods_file)
  load flutter_install_all_ios_pods_file
else
  # Si la ruta anterior falla, intentamos la ruta estándar de Flutter
  load File.join(File.dirname(File.realpath(__FILE__)), 'Flutter', 'podhelper.rb')
end

platform :ios, '15.0'

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  # Ahora que cargamos el archivo arriba, esta función YA debería existir
  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'
    end
  end
end